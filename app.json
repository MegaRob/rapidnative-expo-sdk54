{
  "expo": {
    "name": "The Collective",
    "slug": "the-collective",
    "owner": "beartoe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trailmatch",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beartoe.myapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:trailmatch-49203553-49000.web.app"
      ]
    },
    "android": {
      "newArchEnabled": true,
      "package": "com.robertolsen.thecollective",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1A1F25",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "trailmatch-49203553-49000.web.app",
              "pathPrefix": "/race/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1F25",
          "dark": {
            "backgroundColor": "#1A1F25"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#10b981",
          "defaultChannel": "chat"
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.beartoe.trailmatch",
          "enableGooglePay": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": false,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "NEVER",
      "url": ""
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c2835d8c-92ce-45a2-8630-71ade3a7689d"
      },
      "FIREBASE_API_KEY": "REPLACE_WITH_YOUR_KEY",
      "FIREBASE_AUTH_DOMAIN": "trailmatch-49203553-49000.firebaseapp.com",
      "FIREBASE_PROJECT_ID": "trailmatch-49203553-49000",
      "FIREBASE_STORAGE_BUCKET": "trailmatch-49203553-49000.appspot.com",
      "FIREBASE_MESSAGING_SENDER_ID": "REPLACE_WITH_YOUR_ID",
      "FIREBASE_APP_ID": "REPLACE_WITH_YOUR_APP_ID"
    }
  }
}
