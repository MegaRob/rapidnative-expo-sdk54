# Copy to `.env` and fill in (never commit `.env`).
# Expo loads EXPO_PUBLIC_* at build time. Restart `expo start` after changes.
# NEVER put Stripe secret keys (`sk_live_` / `sk_test_` secret) here — only in Firebase Functions secrets.

# Firebase (Firebase Console → Project settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional — Firebase App Check
# Web: reCAPTCHA v3 — Console → App Check → register Web app → reCAPTCHA.
# EXPO_PUBLIC_APPCHECK_RECAPTCHA_SITE_KEY=
# Native (iOS/Android, dev client / release): Play Integrity + App Attest — register apps in App Check, then use a
# debug token in development (Console → App Check → Manage debug tokens). Same env works for native + web dev helpers.
# EXPO_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=
#
# Native builds need Firebase config files at the repo root (see app.json): `google-services.json` and
# `GoogleService-Info.plist`. Download from Firebase Console → Project settings → Your apps (Android / iOS).
# Replace placeholder IDs inside the committed stubs if builds fail.

# Stripe — publishable key only (Dashboard → Developers → API keys → Publishable key)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
