# Copy to `.env` and fill in (never commit `.env`).
# Expo loads EXPO_PUBLIC_* at build time. Restart `expo start` after changes.
# NEVER put Stripe secret keys (`sk_live_` / `sk_test_` secret) here — only in Firebase Functions secrets.

# Firebase (Firebase Console → Project settings → Your apps)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional — Firebase App Check (web / reCAPTCHA v3). Console → App Check → register Web app → reCAPTCHA.
# EXPO_PUBLIC_APPCHECK_RECAPTCHA_SITE_KEY=
# Dev-only: register a debug token in Console, then paste it (or `true` to print a token in the browser console).
# EXPO_PUBLIC_FIREBASE_APPCHECK_DEBUG_TOKEN=

# Stripe — publishable key only (Dashboard → Developers → API keys → Publishable key)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
