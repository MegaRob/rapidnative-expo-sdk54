rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isDirector() {
      return request.auth != null && request.auth.token.isDirector == true;
    }

    /**
     * Director claim AND the trail doc lists this user as director (scalable ownership check).
     * Equivalent to: isDirector() && get(trails/{trailId}).data.directorId == request.auth.uid
     */
    function isDirectorForTrail(trailId) {
      return isDirector() &&
        trailId != null &&
        get(/databases/$(database)/documents/trails/$(trailId)).data.directorId == request.auth.uid;
    }

    /** Aggregated / external-sourced races (RunSignup, UltraSignup, etc.) — only admin may edit core trail fields. */
    function trailIsAggregator(data) {
      return data.keys().hasAny(['source']) && data.source != 'native';
    }

    // --- Users: PII must not live on the root user doc if others should read public profile ---
    function userSensitiveFieldKeys() {
      return [
        'email',
        'stripeCustomerId',
        'stripeCustomerID',
        'expoPushToken',
        'phoneNumber',
        'phone',
        'address',
        'street',
        'streetAddress',
        'dateOfBirth',
        'dob',
        'legalName',
        'emergencyContact',
      ];
    }

    function userRootHasSensitiveFields(data) {
      return data.keys().hasAny(userSensitiveFieldKeys());
    }

    function canReadOtherUserProfile() {
      return request.auth != null &&
        resource != null &&
        resource.data.get('isPrivate', false) != true &&
        !userRootHasSensitiveFields(resource.data);
    }

    // --- USERS COLLECTION ---
    // Read: peers see only "public" root docs (no sensitive keys, not private). Owner & admin read all.
    // Write: owner updates own doc; admins may update any. Move email/stripe/tokens to users/{uid}/private/*.
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        isAdmin() ||
        canReadOtherUserProfile()
      );

      // Create may include legacy PII on root; peers still cannot read until doc has no sensitive keys + not private
      allow create: if request.auth != null && request.auth.uid == userId;

      allow update: if request.auth != null && (
        (
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(userSensitiveFieldKeys())
        ) ||
        isAdmin()
      );

      allow delete: if request.auth != null && (
        request.auth.uid == userId || isAdmin()
      );

      // --- ADVANCED CHAT NOTIFICATION RULE ---
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hasUnreadMessages'])
        )
      );

      // Sensitive / PII bucket — owner or admin only
      match /private/{docId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId || isAdmin()
        );
        allow create, update, delete: if request.auth != null && (
          request.auth.uid == userId || isAdmin()
        );
      }

      // Peer-safe mirror for chat / inbox (no PII). Owner syncs allowlisted fields from root.
      match /publicDisplay/{docId} {
        allow read: if request.auth != null;
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }

      match /savedRaces/{raceId} {
        allow read, create, delete: if request.auth != null && request.auth.uid == userId;
        allow update: if false;
      }
      match /dislikedRaces/{raceId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // --- END USERS COLLECTION ---

    match /trails/{trailId} {
      allow read: if request.auth != null;
      // Directors may create only native races; aggregated catalog races are admin-only to create.
      allow create: if isAdmin() ||
        (isDirector() &&
          request.resource.data.directorId == request.auth.uid &&
          !trailIsAggregator(request.resource.data));
      // Native trails: admin or owning director. Aggregator-sourced trails: admin only.
      allow update: if isAdmin() ||
        (isDirector() &&
          resource.data.directorId == request.auth.uid &&
          !trailIsAggregator(resource.data) &&
          !trailIsAggregator(request.resource.data));
      allow delete: if isAdmin() ||
        (isDirector() &&
          resource.data.directorId == request.auth.uid &&
          !trailIsAggregator(resource.data));
    }

    // Rolling 24h detail views — one doc per viewer. viewedAt must be server time (use FieldValue.serverTimestamp() in client).
    match /trail_social/{trailId}/viewers/{viewerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == viewerId &&
        request.resource.data.trailId == trailId &&
        request.resource.data.keys().hasOnly(['trailId', 'viewedAt']) &&
        request.resource.data.viewedAt == request.time;
      allow update: if request.auth != null &&
        request.auth.uid == viewerId &&
        request.resource.data.trailId == trailId &&
        request.resource.data.keys().hasOnly(['trailId', 'viewedAt']) &&
        resource.data.trailId == trailId &&
        request.resource.data.viewedAt == request.time;
      allow delete: if request.auth != null && request.auth.uid == viewerId;
    }

    match /raceGuides/{guideId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || isDirectorForTrail(guideId);
    }

    // --- MATCHES ---
    // "Other runners" lists query matches by trailId and must read *other users'* documents.
    // Per-doc "only my userId" would break discovery; tighten later via trail rosters or Cloud Functions.
    match /matches/{matchId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;

      allow read: if request.auth != null;

      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;

      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPinned']);
    }

    // Participant: deterministic id (uid_uid) or userIds array (required for array-contains inbox queries).
    function chatParticipantViaUserIds(chatId) {
      let chat = get(/databases/$(database)/documents/chats/$(chatId));
      return chat != null && request.auth.uid in chat.data.get('userIds', []);
    }

    function isChatParticipant(chatId) {
      return request.auth.uid in chatId.split('_') || chatParticipantViaUserIds(chatId);
    }

    // --- CHATS ---
    match /chats/{chatId} {
      allow read: if request.auth != null && (
        request.auth.uid in chatId.split('_') ||
        (resource != null && request.auth.uid in resource.data.get('userIds', [])) ||
        isAdmin()
      );

      allow create: if request.auth != null && request.auth.uid in chatId.split('_');

      allow update: if request.auth != null && (
        request.auth.uid in chatId.split('_') ||
        (resource != null && request.auth.uid in resource.data.get('userIds', []))
      );

      allow delete: if request.auth != null && (
        request.auth.uid in chatId.split('_') ||
        (resource != null && request.auth.uid in resource.data.get('userIds', []))
      );

      match /messages/{messageId} {
        allow read, create: if request.auth != null && isChatParticipant(chatId);
        allow update: if request.auth != null &&
          isChatParticipant(chatId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
        allow delete: if request.auth != null &&
          resource != null &&
          request.auth.uid == resource.data.userId;
      }
    }

    match /raceRequests/{requestId} {
      allow create: if true;
      allow read: if request.auth != null && (
        isAdmin() ||
        (isDirector() && resource.data.directorId == request.auth.uid)
      );
      allow update: if request.auth != null && (
        isAdmin() ||
        (isDirector() && resource.data.directorId == request.auth.uid)
      );
      allow delete: if false;
    }

    match /blocks/{blockId} {
      allow read: if request.auth != null && (
        request.auth.uid in blockId.split('_') ||
        (resource != null && (
          request.auth.uid == resource.data.blockerId ||
          request.auth.uid == resource.data.blockedId
        ))
      );
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.blockerId;
      allow delete: if request.auth != null &&
        resource != null &&
        request.auth.uid in blockId.split('_') &&
        (request.auth.uid == resource.data.blockerId ||
         request.auth.uid == resource.data.blockedId);
      allow update: if false;
    }

    match /artifacts/{appId}/public/data/reports/{reportId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.reporterId;
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /artifacts/{appId}/users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /artifacts/{appId}/public/data/community_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.authorId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['interactionCount']);
    }

    match /artifacts/{appId}/public/data/community_posts/{postId}/interested/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    match /artifacts/{appId}/public/data/registrations/{registrationId} {
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;

      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         isAdmin() ||
         isDirectorForTrail(resource.data.trailId));

      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         isAdmin() ||
         isDirectorForTrail(resource.data.trailId));

      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    // --- REGISTRATIONS (top-level) ---
    // Any signed-in user may read (needed for race-details / social: query by trailId lists other
    // registrants). Docs may include name/bib — tighten later via a public roster subcollection or CF.
    match /registrations/{registrationId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;

      allow update: if request.auth != null && (
        (request.auth.uid == resource.data.userId ||
         isDirectorForTrail(resource.data.trailId)) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkedIn', 'checkedInAt'])
      );

      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    match /completed_races/{completedId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         isAdmin() ||
         isDirectorForTrail(resource.data.trailId));
      allow create: if request.auth != null &&
        (request.auth.uid == request.resource.data.userId ||
         isDirectorForTrail(request.resource.data.trailId));
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.userId ||
         isDirectorForTrail(resource.data.trailId));
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.userId;
    }

    match /system/{document=**} {
      allow read, write: if false;
    }

    // Immutable audit trail — written only by Cloud Functions (Admin SDK).
    // Includes top-level log docs and tombstones under audit_logs/deletions/trails/{trailId}.
    match /audit_logs/{document=**} {
      allow read: if isAdmin();
      allow create, update, delete: if false;
    }

    match /payments/{paymentId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        isDirectorForTrail(resource.data.trailId)
      );
      allow write: if false;
    }
  }
}
